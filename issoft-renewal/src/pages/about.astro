---
// 회사소개 Page — (주)이즈소프트 (피드백 반영 리뉴얼)
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const lang = 'ko';
const currentPath = '/about/';

// Modern corporate SVG icons for the 5 core values
const iconMap = {
  cpu: `<svg xmlns="http://www.w3.org/2000/svg" class="vision-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <rect x="4" y="4" width="16" height="16" rx="2" />
    <rect x="9" y="9" width="6" height="6" />
    <path d="M9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 15h3M1 9h3M1 15h3" />
  </svg>`,
  users: `<svg xmlns="http://www.w3.org/2000/svg" class="vision-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
    <circle cx="9" cy="7" r="4" />
    <path d="M22 21v-2a4 4 0 0 0-3-3.87" />
    <path d="M16 3.13a4 4 0 0 1 0 7.75" />
  </svg>`,
  lightbulb: `<svg xmlns="http://www.w3.org/2000/svg" class="vision-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .6 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" />
    <path d="M9 18h6M10 22h4" />
  </svg>`,
  shield: `<svg xmlns="http://www.w3.org/2000/svg" class="vision-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
    <path d="m9 11 2 2 4-4" />
  </svg>`,
  chart: `<svg xmlns="http://www.w3.org/2000/svg" class="vision-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="m22 7-8.5 8.5-5-5L2 17" />
    <path d="M16 7h6v6" />
  </svg>`,
};

const visions = [
  {
    icon: 'cpu',
    title: '원천 기술력 확보',
    desc: '독자적인 L-CRIS 프레임워크와 기계 제어 기술력을 기반으로 라이선스 종속이 없는 고효율 솔루션을 공급합니다.',
  },
  {
    icon: 'users',
    title: '인간 존중',
    desc: '인간 중심의 현장 친화적 인터페이스를 설계하여 작업 효율을 극대화하고 제조 공정의 안전을 확보합니다.',
  },
  {
    icon: 'lightbulb',
    title: '변화와 혁신',
    desc: 'C/S 윈도우 어플리케이션은 물론 최신 웹 표준 기술까지 신속히 포착하여 급변하는 산업 패러다임을 선도합니다.',
  },
  {
    icon: 'shield',
    title: '고객 만족',
    desc: '단순 시스템 납품에 그치지 않고, 가용 유지보수 및 맞춤 컨설팅을 통해 고객사의 지속적인 성장을 보장합니다.',
  },
  {
    icon: 'chart',
    title: '가치 창조',
    desc: '원자재 손실 절감, 품질 유출 차단 등 현업 중심의 실효성 높은 제조 인프라 구축으로 실질적 경영 가치를 창조합니다.',
  },
];

const certifications = [
  {
    title: 'ISO 9001:2015 품질경영인증',
    desc: '소프트웨어 개발 및 공급 부문 품질경영 시스템 공식 규격 준수',
    org: '인증기관: ICR (International Certification Registrar)',
    image: '/images/certs/cert_5.png',
  },
  {
    title: '경영혁신형 중소기업 (Main-Biz)',
    desc: '마케팅, 조직, 프로세스 등 다방면의 경영 혁신 성과 공인',
    org: '인증기관: 중소벤처기업부',
    image: '/images/certs/cert_4.png',
  },
  {
    title: '벤처기업 확인 (혁신성장유형)',
    desc: '독보적인 기술 경쟁력과 비즈니스 성장 잠재력 인증',
    org: '인증기관: 기술보증기금 / 벤처기업확인기관',
    image: '/images/certs/cert_1.png',
  },
  {
    title: '연구개발전담부서 인정',
    desc: '지속적인 스마트공장 원천기술 연구 및 맞춤 솔루션 고도화를 위한 전용 연구 조직 운영',
    org: '인증기관: 한국산업기술진흥협회 (KOITA)',
    image: '/images/certs/cert_3.png',
  },
  {
    title: 'L-CRIS 프로그램 저작권',
    desc: '초고속 대용량 산업용 프레임워크 L-CRIS 솔루션의 소프트웨어 지적재산권 독점 등록',
    org: '등록기관: 한국저작권위원회 (등록번호: C-2014-018475)',
    image: '/images/certs/cert_2.png',
  },
];
---

<BaseLayout
  title="회사소개 | (주)이즈소프트"
  description="이즈소프트의 VISION과 조직 구성을 소개합니다. 원천기술력과 인간존중을 기반으로 고객만족을 추구합니다."
  lang={lang}
  currentPath={currentPath}
>
  <Header slot="header" lang={lang} currentPath={currentPath} />

  <!-- Page Hero -->
  <section class="page-hero" aria-label="페이지 헤더">
    <div class="container">
      <div class="page-hero__breadcrumb">
        <a href="/">홈</a>
        <span>&gt;</span>
        <span>회사소개</span>
      </div>
      <h1 class="page-hero__title">About Us</h1>
      <p class="page-hero__desc">미래를 함께하는 IT 성공 파트너, 이즈소프트입니다.</p>
    </div>
  </section>

  <!-- Company Intro Section -->
  <section class="section" aria-labelledby="intro-title">
    <div class="container">
      <!-- Left-Right Split Greeting Layout (Left: Paper Card, Right: CI Wrapper) -->
      <div class="about-intro fade-in">
        <div class="about-greeting-card">
          <h2 class="greeting-title" id="intro-title">인사말</h2>
          <div class="greeting-divider"></div>
          
          <div class="greeting-body">
            <p>
              (주)이즈소프트는 스마트공장 구축, 그중에서도 MES/POP 시스템을 중심으로 성장해 온 기업입니다. 2013년 설립 이후 공장 자동화와 엔터프라이즈 SI 분야에서 현장 경험을 쌓아왔으며, 2016년부터는 중소벤처기업부 스마트공장 보급사업 공급기업으로 등록되어 국내 제조 현장의 디지털 전환을 지원하고 있습니다.
            </p>
            <p>
              자체 개발한 L-CRIS 프레임워크로 대용량 생산 데이터를 안정적으로 처리하는 고성능 관리 시스템을 구축하는 한편, 제조 현장을 넘어 각 기업의 특성에 맞춘 다양한 솔루션도 웹으로 설계·구축하고 있습니다. 최근에는 이러한 웹·모바일 기반 사업의 비중이 점차 커지며 이즈소프트의 또 다른 성장축으로 자리잡고 있습니다.
            </p>
          </div>

          <div class="greeting-signature">
            <p>
              이즈소프트의 모든 임직원은 고객의 니즈를 정확히 이해하고,<br />
              기술 그 이상의 신뢰를 만들어가는 파트너가 되겠습니다. 늘 관심 가져주셔서 감사합니다.
            </p>
            <strong class="greeting-sign-text">이즈소프트 임직원 일동</strong>
          </div>
        </div>
        
        <div class="about-intro__side-column">
          <div class="about-intro__image-wrapper">
            <img src="/images/ci1.png" alt="ISSOFT 로고 데코레이션" class="about-intro__ci-img" loading="lazy" />
            <span class="about-intro__ci-text">(주)이즈소프트</span>
          </div>
          
          <div class="supplier-cert-box">
            <div class="supplier-cert-box__badge">공식 인증</div>
            <div class="supplier-cert-box__content">
              <h4>중소벤처기업부 스마트공장 지원사업 공급기업</h4>
              <p>
                (주)이즈소프트는 <strong>2016년부터 스마트공장 구축 지원사업을 성공적으로 수행</strong>해 오고 있으며, 스마트공장사업관리시스템 <strong>공급기업 Pool에 정식 등록</strong>된 제조 IT 파트너입니다.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Vision Section (Concise Numbers instead of Emojis - Feedback #2) -->
  <section class="section section--alt" aria-labelledby="vision-title">
    <div class="container">
      <div class="section__header fade-in">
        <h2 class="section__title" id="vision-title">VISION</h2>
        <p class="section__subtitle">이즈소프트가 지켜나가는 5대 가치</p>
      </div>

      <div class="vision-grid-concise">
        {visions.map((v) => (
          <div class="vision-card fade-in">
            <div class="vision-card__header">
              <div class="vision-card__icon-container">
                <Fragment set:html={iconMap[v.icon]} />
              </div>
              <h3 class="vision-card__title">{v.title}</h3>
            </div>
            <p class="vision-card__text">{v.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Organization Section (Refined HTML/CSS Org Tree - Connector Alignment - Feedback #1) -->
  <section class="section" aria-labelledby="org-title">
    <div class="container">
      <div class="section__header fade-in">
        <h2 class="section__title" id="org-title">조직도</h2>
        <p class="section__subtitle">고객 신뢰와 최상의 스마트제조 품질을 실현하는 이즈소프트의 핵심 조직망</p>
      </div>
      
      <div class="org-tree-wrapper fade-in">
        <div class="org-dot-pattern"></div> <!-- Ambient grid pattern -->

        <!-- Root Node (CEO) -->
        <div class="org-node org-node--ceo">
          <span class="org-node__badge">PRESIDENT</span>
          <strong>대표이사</strong>
        </div>

        <!-- Vertical Spacer block to guarantee alignment spacing before branches (Feedback #1) -->
        <div class="org-spacer-trunk"></div>

        <div class="org-tree-branches">
          <!-- Branch 1: 개발부서 -->
          <div class="org-branch-column org-branch-column--dev">
            <div class="org-node org-node--dept org-node--dept-dev">
              <span class="dept-badge">ENGINEERING</span>
              <strong>개발부서</strong>
            </div>
            <div class="org-tree-subnodes">
              <!-- Dev 1 Team -->
              <div class="org-node org-node--team org-node--team-dev">
                <strong class="team-name">개발 1팀</strong>
                <span class="team-desc">MES / POP</span>
              </div>
              <!-- Dev 2 Team -->
              <div class="org-node org-node--team org-node--team-dev">
                <strong class="team-name">개발 2팀</strong>
                <span class="team-desc">Web / Mobile</span>
              </div>
              <!-- R&D -->
              <div class="org-node org-node--team org-node--team-dev">
                <strong class="team-name">연구개발 전담부서</strong>
                <span class="team-desc">L-CRIS / Core Tech</span>
              </div>
            </div>
          </div>

          <!-- Branch 2: 지원부서 -->
          <div class="org-branch-column org-branch-column--support">
            <div class="org-node org-node--dept org-node--dept-support">
              <span class="dept-badge">BUSINESS SUPPORT</span>
              <strong>지원부서</strong>
            </div>
            <div class="org-tree-subnodes">
              <!-- Sales & Tech -->
              <div class="org-node org-node--team org-node--team-support">
                <strong class="team-name">영업 / 기술</strong>
                <span class="team-desc">Customer Relations</span>
              </div>
              <!-- Planning & Admin -->
              <div class="org-node org-node--team org-node--team-support">
                <strong class="team-name">기획 / 관리</strong>
                <span class="team-desc">Planning & Finance</span>
              </div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- Certifications Section -->
  <section class="section section--alt" aria-labelledby="cert-title">
    <div class="container">
      <div class="section__header fade-in">
        <h2 class="section__title" id="cert-title">인증 및 지식재산권</h2>
        <p class="section__subtitle">이즈소프트의 공인된 기술력과 규격화된 품질 경영 체계를 입증하는 주요 인증서입니다.</p>
      </div>

      <div class="cert-showcase fade-in">
        <!-- Left: Image Viewer Frame -->
        <div class="cert-showcase__viewer">
          <div class="cert-image-frame">
            <img 
              id="cert-display-img" 
              src={certifications[0].image} 
              alt={`${certifications[0].title} 원본`} 
              class="cert-display-img" 
            />
          </div>
        </div>

        <!-- Right: Interactive Selector List -->
        <div class="cert-showcase__selector">
          {certifications.map((c, idx) => (
            <button 
              type="button"
              class={`cert-select-btn ${idx === 0 ? 'active' : ''}`}
              data-img={c.image}
              data-alt={c.title}
              onclick={`
                const img = document.getElementById('cert-display-img');
                if (img) {
                  img.style.opacity = '0';
                  setTimeout(() => {
                    img.src = '${c.image}';
                    img.alt = '${c.title} 원본';
                    img.style.opacity = '1';
                  }, 150);
                }
                document.querySelectorAll('.cert-select-btn').forEach(btn => btn.classList.remove('active'));
                this.classList.add('active');
              `}
            >
              <span class="cert-select-btn__num">{String(idx + 1).padStart(2, '0')}</span>
              <div class="cert-select-btn__content">
                <h3 class="cert-select-btn__title">{c.title}</h3>
                <p class="cert-select-btn__desc">{c.desc}</p>
                <span class="cert-select-btn__org">{c.org}</span>
              </div>
            </button>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang={lang} />
</BaseLayout>

<style>
  /* Refactored Left-Right Split Greeting Layout */
  .about-intro {
    display: grid;
    grid-template-columns: 1.25fr 0.75fr;
    gap: var(--space-2xl);
    align-items: stretch; /* Make both columns the same height */
  }

  /* Left Greeting Card (Parchment Paper style) */
  .about-greeting-card {
    background-color: #fdfdfa; /* Warm letterhead paper ivory color */
    border: 1px solid #e8e6df; /* Soft warm border */
    border-radius: var(--radius-xl);
    padding: var(--space-2xl) var(--space-xl);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.02), 0 1px 3px rgba(0, 0, 0, 0.01);
    position: relative;
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .about-greeting-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: var(--radius-xl);
    background-image: linear-gradient(rgba(0, 0, 0, 0.01) 1px, transparent 1px);
    background-size: 100% 24px;
    opacity: 0.4;
    pointer-events: none;
  }

  .greeting-title {
    font-size: var(--font-size-2xl);
    font-weight: 800;
    color: var(--color-text-primary);
    margin-bottom: var(--space-xs); /* Reduced spacing above divider */
    position: relative;
    display: inline-block;
  }

  .greeting-body {
    z-index: 2;
    position: relative;
    margin-bottom: var(--space-lg);
  }

  .greeting-body p {
    font-size: var(--font-size-base);
    color: var(--color-text-secondary);
    line-height: 1.85;
    margin-bottom: var(--space-md);
    text-align: center;
    word-break: keep-all;
  }

  .greeting-body p:last-child {
    margin-bottom: 0;
  }

  .greeting-signature {
    z-index: 2;
    position: relative;
    border-top: 1px dashed #e2e0d9;
    padding-top: var(--space-lg);
    max-width: 480px;
    margin: auto auto 0 auto; /* push to bottom and center */
    width: 100%;
  }

  .greeting-signature p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.65;
    margin-bottom: var(--space-xs); /* Increased line-to-line spacing slightly */
  }

  .greeting-divider {
    width: 40px;
    height: 2px;
    background: var(--brand-gradient);
    margin: 0 auto var(--space-lg) auto;
  }

  .greeting-sign-text {
    display: block; /* Set block to apply top margin correctly */
    font-size: var(--font-size-md);
    color: var(--color-text-primary);
    font-weight: 700;
    letter-spacing: 0.05em;
    margin-top: var(--space-xl); /* Added comfortable 24px margin above sign text */
  }

  /* Right Side Stacked Column */
  .about-intro__side-column {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .about-intro__image-wrapper {
    display: flex;
    flex-direction: column; /* Stack vertically for logo and text */
    justify-content: center;
    align-items: center;
    background-color: var(--color-bg-alt);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
    border: 1px solid var(--color-border-light);
    flex: 0.9;
    min-height: 150px;
    gap: var(--space-xs);
  }

  .about-intro__ci-img {
    max-width: 90%; /* Enlarged from 82% */
    max-height: 110px; /* Enlarged from 90px */
    height: auto;
    object-fit: contain;
    display: block;
  }

  .about-intro__ci-text {
    font-size: var(--font-size-md); /* Enlarged from base (16px) to md (18px) */
    font-weight: 800; /* Extra bold */
    color: var(--color-text-primary);
    letter-spacing: -0.02em;
    margin-top: var(--space-xs);
  }

  /* Embedded Supplier certification box (Vertical Layout) */
  .supplier-cert-box {
    background: var(--color-brand-orange-light);
    border: 1px solid rgba(242, 101, 34, 0.2);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
    display: flex;
    flex-direction: column; /* Stack vertically for tight side column */
    gap: var(--space-xs);
    justify-content: center;
    flex: 1.1; /* Reduced weight from 1.3 to remove excess empty space */
    text-align: left;
  }

  .supplier-cert-box__badge {
    background: var(--brand-gradient);
    color: var(--color-white);
    font-size: var(--font-size-xs); /* Increased from 9px to xs (12px) */
    font-weight: 700;
    padding: 5px 12px;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    white-space: nowrap;
    align-self: flex-start;
  }

  .supplier-cert-box__content h4 {
    font-size: var(--font-size-base); /* Increased from sm (14px) to base (16px) */
    font-weight: 700;
