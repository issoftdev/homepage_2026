---
// 연혁 Page — (주)이즈소프트
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const lang = 'ko';
const currentPath = '/history/';

const events = [
  {
    date: '2020. 04',
    title: '이즈빌딩 사옥 확장 이전',
    desc: '대구광역시 동구 소재 이즈빌딩 사옥 5층 입주',
  },
  {
    date: '2017. 07',
    title: 'ISO 9001:2015',
    desc: 'ISO 9001:2015 품질경영시스템 인증 획득',
  },
  {
    date: '2016. 06',
    title: '스마트공장 보급사업 공급기업 등록',
    desc: '중소벤처기업부 스마트공장 지원사업 공급기업 풀(Pool) 정식 등록 및 구축 개시',
  },
  {
    date: '2015. 03',
    title: '대구지식서비스센터로 사무실 이전',
    desc: '대구테크노파크 지식서비스센터 입주 및 인프라 고도화',
  },
  {
    date: '2014. 11',
    title: '연구개발전담부서 인증',
    desc: '한국산업기술진흥협회(KOITA)로부터 연구개발전담부서 설립 인증서 획득',
  },
  {
    date: '2014. 10',
    title: '벤처기업 인증 획득',
    desc: '기술보증기금(KIBO)으로부터 창업벤처중소기업 인증 획득 (창업 1년 내)',
  },
  {
    date: '2014. 07',
    title: 'L-CRIS 저작권 등록',
    desc: '자체 개발 제조관리 솔루션 L-CRIS가 한국저작권위원회 정식 프로그램 저작권 등록',
  },
  {
    date: '2014. 05',
    title: '이즈소프트 법인전환',
    desc: '주식회사 이즈소프트 법인사업자 전환 설립',
  },
  {
    date: '2013. 12',
    title: '소프트웨어사업자 신고',
    desc: '한국소프트웨어산업협회(KOSA) 소프트웨어사업자 등록',
  },
  {
    date: '2013. 11',
    title: '이즈소프트 창립',
    desc: '기업정보화 솔루션 기업 이즈소프트 설립',
  },
];
---

<BaseLayout
  title="연혁 | (주)이즈소프트"
  description="이즈소프트의 설립부터 지속적인 기술 혁신과 비즈니스 확장 과정을 소개하는 연혁 페이지입니다."
  lang={lang}
  currentPath={currentPath}
>
  <Header slot="header" lang={lang} currentPath={currentPath} />

  <!-- Page Hero -->
  <section class="page-hero" aria-label="페이지 헤더">
    <div class="container">
      <div class="page-hero__breadcrumb">
        <a href="/">홈</a>
        <span>&gt;</span>
        <span>연혁</span>
      </div>
      <h1 class="page-hero__title">Our History</h1>
      <p class="page-hero__desc">고객과 함께 걸어온 이즈소프트의 성장과 도전의 역사입니다.</p>
    </div>
  </section>

  <!-- Timeline Section -->
  <section class="section" aria-labelledby="history-title">
    <div class="container">
      <h2 class="sr-only" id="history-title">연혁 타임라인</h2>
      <div class="timeline">
        {events.map((event) => (
          <div class="timeline__item fade-in">
            <div class="timeline__dot"></div>
            <div class="timeline__date">{event.date}</div>
            <h3 class="timeline__title">{event.title}</h3>
            <p class="timeline__desc">{event.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Footer slot="footer" lang={lang} />
</BaseLayout>
