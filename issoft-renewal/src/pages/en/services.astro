---
// Services Page (English) — ISSOFT Software Co.,Ltd (Feedback Incorporated Redesign)
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const lang = 'en';
const currentPath = '/en/services/';
---

<BaseLayout
  title="Services | ISSOFT Software Co.,Ltd"
  description="Explore ISSOFT's smart factory portfolio: POP/MES solutions, MICS equipment interface controls, L-CRIS high-speed Windows desktop Client/Server framework, SQM shop-floor quality containment, and custom Web business applications."
  lang={lang}
  currentPath={currentPath}
>
  <Header slot="header" lang={lang} currentPath={currentPath} />

  <!-- Page Hero -->
  <section class="page-hero" aria-label="Page Header">
    <div class="container">
      <div class="page-hero__breadcrumb">
        <a href="/en/">Home</a>
        <span>&gt;</span>
        <span>Services</span>
      </div>
      <h1 class="page-hero__title">Our Services</h1>
      <p class="page-hero__desc">Discover ISSOFT's intelligent smart software suites driving digital transformation.</p>
    </div>
  </section>

  <!-- Service Tabs Section -->
  <section class="section" aria-labelledby="services-main-title">
    <div class="container">
      <h2 class="sr-only" id="services-main-title">Our Solutions</h2>      <!-- Sticky Navigation Bar & Stacked Panels -->
      <div class="services-container">
        <!-- Tab Links / Navigation -->
        <div class="services-nav">
          <a href="#tab-pop" class="services-nav__item">
            <div class="services-nav__icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="9" rx="1"/><rect x="14" y="3" width="7" height="5" rx="1"/><rect x="14" y="12" width="7" height="9" rx="1"/><rect x="3" y="16" width="7" height="5" rx="1"/><path d="M7 12v4M17 8v4M10 6h4M10 18h4"/>
              </svg>
            </div>
            <span class="services-nav__text">POP / MES</span>
          </a>
          <a href="#tab-mics" class="services-nav__item">
            <div class="services-nav__icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M2 10v4M6 6v12M10 3v18M14 8v8M18 5v14M22 10v4"/>
              </svg>
            </div>
            <span class="services-nav__text">MICS Control</span>
          </a>
          <a href="#tab-lcris" class="services-nav__item">
            <div class="services-nav__icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
              </svg>
            </div>
            <span class="services-nav__text">L-CRIS Framework</span>
          </a>
          <a href="#tab-sqm" class="services-nav__item">
            <div class="services-nav__icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 11 11 13 15 9"/>
              </svg>
            </div>
            <span class="services-nav__text">Quality Control (SQM)</span>
          </a>
          <a href="#tab-web" class="services-nav__item">
            <div class="services-nav__icon">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
              </svg>
            </div>
            <span class="services-nav__text">Web Custom Solutions</span>
          </a>
        </div>

        <!-- Stacked Content Areas -->
        <div class="services-content">
          <!-- 1. POP/MES Content -->
          <div class="services-panel" id="tab-pop">
            <h3 class="panel-title">POP / MES (Manufacturing Execution System)</h3>
            <p class="panel-lead">Real-time data pipeline orchestration maximizing floor transparency and digital intelligence.</p>

            <div class="panel-section">
              <h4>POP(Point Of Production) & MES Overview</h4>
              <p>ISSOFT's POP/MES system acts as the digital nervous system for modern manufacturing facilities. Far exceeding basic digital data recording, it integrates production floors through dedicated networks to capture vital raw metrics (target vs. actual output, downtime root causes, material yields, and product routing) in real time. By visualizing process bottlenecks, MICS enables immediate floor corrective controls.</p>
            </div>

            <div class="panel-section grid grid--2">
              <div>
                <h4>Strategic Objectives</h4>
                <p>Build real-time data-driven decision frameworks to increase production flexibility and prevent management overhead. We deliver high-fidelity floor dashboards so production supervisors can identify anomalies immediately and execute preventive adjustments.</p>
                <ul class="panel-list">
                  <li>Real-time tracking of work progress to secure precise shipping forecasts</li>
                  <li>Predictive analytics on process parameters to prevent machine breakdowns</li>
                  <li>Granular product traceability from raw material feed to final packaging</li>
                  <li>On-floor digital work instruction routing to eliminate manual operator errors</li>
                </ul>
              </div>
              <div>
                <h4>Quantitative Business Value</h4>
                <div class="effect-cards">
                  <div class="effect-card"><span class="effect-card__tag">Lead Time</span> Reduce manufacturing lead times by 15%+</div>
                  <div class="effect-card"><span class="effect-card__tag">Inventory</span> Minimize work-in-progress (WIP) buffers</div>
                  <div class="effect-card"><span class="effect-card__tag">Yield</span> Boost overall equipment effectiveness (OEE)</div>
                  <div class="effect-card"><span class="effect-card__tag">Cost</span> Cut management hours and achieve cost innovation</div>
                </div>
              </div>
            </div>

            <div class="panel-section">
              <h4>Smart Factory Data Integration Architecture</h4>
              
              <!-- Redrawn HTML/CSS Diagram based strictly on /images/0201.jpg -->
              <div class="mes-pop-classic-container">
                <div class="mes-pop-classic">
                  <!-- Left Text: MES -->
                  <div class="classic-node classic-node--mes">MES</div>
                  
                  <!-- Left Connector (Dot is near MES) -->
                  <div class="classic-line classic-line--left">
                    <div class="classic-dot"></div>
                    <div class="classic-connector"></div>
                  </div>

                  <!-- Center Circle -->
                  <div class="classic-circle-outer">
                    <div class="classic-circle-inner">
                      <span>Production<br/>System</span>
                    </div>
                  </div>

                  <!-- Right Connector (Dot is near POP) -->
                  <div class="classic-line classic-line--right">
                    <div class="classic-connector"></div>
                    <div class="classic-dot"></div>
                  </div>

                  <!-- Right Text: POP -->
                  <div class="classic-node classic-node--pop">POP</div>
                </div>

                <!-- Three Dots -->
                <div class="classic-dots">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>

                <!-- Description Text -->
                <p class="classic-desc">
                  We support intuitive, transparent management through MES and POP integration,<br/>
                  guaranteeing corporate competitiveness through systematic production methodologies.
                </p>
              </div>
            </div>
          </div>

          <!-- 2. MICS Content -->
          <div class="services-panel" id="tab-mics">
            <h3 class="panel-title">MICS (Machine Interface & Control System)</h3>
            <p class="panel-lead">Heterogeneous equipment protocol integration and predictive diagnostics securing floor uptime.</p>

            <div class="panel-section">
              <h4>MICS Overview</h4>
              <p>MICS is an intelligent platform designed to unify machine communication across varied vintages and manufacturers. By providing both desktop and mobile monitoring clients, MICS enables off-site engineers to check machine conditions and secures automated data assets of machine run histories.</p>
            </div>

            <div class="panel-section">
              <h4>MICS Key Value Drivers</h4>
              <div class="table-wrapper">
                <table>
                  <thead>
                    <tr>
                      <th style="width: 25%">Key Drivers</th>
                      <th style="width: 75%">Technical Deliverables</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td><strong>PC-Based High-Speed Control</strong></td>
                      <td>Runs multi-threaded parallel control loops and modular interface drivers to ensure quick fail-over recovery. Delivers control reliability equivalent to high-cost PLC hardware on cost-efficient PC platforms.</td>
                    </tr>
                    <tr>
                      <td><strong>Heterogeneous Interface Flexibility</strong></td>
                      <td>Features a built-in control model simulation tool to verify logic paths before hardware attachment. Native support for OPC UA, Modbus, and custom serial protocols ensures seamless upper-system links.</td>
                    </tr>
                    <tr>
                      <td><strong>Fast Business Value Return</strong></td>
                      <td>Equipped with intuitive visual layout tools, enabling engineers to customize device monitoring screens and client dashboards rapidly without writing custom application codes from scratch.</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- 3. L-CRIS Content -->
          <div class="services-panel" id="tab-lcris">
            <h3 class="panel-title">L-CRIS (High-Speed Windows Client/Server Development Framework)</h3>
            <p class="panel-lead">High-volume transactional logic processing coupled with automated Windows desktop UI generation.</p>

            <div class="panel-section">
              <h4>L-CRIS (Lean-based Creative Industry Solution) Overview</h4>
              <p>Born from ISSOFT's core R&D program, L-CRIS is a high-performance Windows desktop application framework designed to process high-volume industrial transaction loads with zero latency. Bypassing the calculation limits of standard web browsers, L-CRIS features an optimized local data binding architecture. This enables managers to manipulate large data grids and build multi-dimensional reports instantly without UI lag.</p>
            </div>

            <div class="panel-section">
              <h4>L-CRIS Core Architecture Features</h4>

              <div class="lcris-features">
                <div class="lcris-feature">
                  <h5>01 Modernizing Legacy Environments with Minimal Custom Code</h5>
                  <p>Ensures ultra-fast screen rendering speeds while minimizing expensive modifications to existing legacy views and database structures.</p>
                  <img src="/images/l_cris/1.png" alt="L-CRIS high-speed data bridge" loading="lazy" />
                </div>

                <div class="lcris-feature">
                  <h5>02 Pivot Multi-Dimensional Analysis & Charts</h5>
                  <p>Transforms raw production databases into pivoting grids with a simple drag-and-drop, instantly rendering professional graphs for key business indicators.</p>
                  <div class="grid grid--2">
                    <img src="/images/l_cris/2.png" alt="Pivot grid analysis 1" loading="lazy" />
                    <img src="/images/l_cris/3.png" alt="Pivot grid analysis 2" loading="lazy" />
                    <img src="/images/l_cris/4.png" alt="Automated chart display 1" loading="lazy" />
                    <img src="/images/l_cris/5.png" alt="Automated chart display 2" loading="lazy" />
                  </div>
                  <img src="/images/l_cris/6.png" alt="High-capacity report grid layout" style="margin-top: var(--space-md);" loading="lazy" />
                </div>

                <div class="lcris-feature">
                  <h5>03 Template-Based Screen Builders & Virtual Cloning</h5>
                  <p>Allows developers to bind filter parameters and data columns inside visual popup maps without writing code, and clone complex layouts to create new metric views instantly.</p>
                  <div class="grid grid--2">
                    <img src="/images/l_cris/7.png" alt="Filter condition editor" loading="lazy" />
                    <img src="/images/l_cris/8.png" alt="Grid mapper interface" loading="lazy" />
                  </div>
                </div>

                <div class="lcris-feature">
                  <h5>04 Multi-Criteria Query Optimization</h5>
                  <p>Optimizes calculation loads by using native Windows OS resources to run complex multi-criteria filters and data associations simultaneously.</p>
                  <img src="/images/l_cris/9.png" alt="L-CRIS composite dashboard view" loading="lazy" />
                </div>
              </div>
            </div>
          </div>

          <!-- 5. SQM Content -->
          <div class="services-panel" id="tab-sqm">
            <h3 class="panel-title">Shop-floor Quality Management (SQM)</h3>
            <p class="panel-lead">Real-time quality log digitization and automated defect containment.</p>

            <div class="panel-section">
              <h4>SQM Overview</h4>
              <p>A digital QA system to ensure zero-defect quality standards. SQM replaces paper inspection log sheets with connected tablets and digital measurement gauges. It records initial, middle, and final inspection logs directly to QA databases to secure overall product traceability.</p>
            </div>

            <div class="panel-section grid grid--2">
              <div class="card card--accent">
                <div class="card__body">
                  <h5 class="card__title">Connected Inspection Interfaces</h5>
                  <p class="card__text">Connects digital micrometers via direct digital interfaces or Serial links to record dimensional measurements automatically, removing manual data entry errors.</p>
                </div>
              </div>
              <div class="card card--accent">
                <div class="card__body">
                  <h5 class="card__title">Fool-Proof Containment Locks</h5>
                  <p class="card__text">Sends immediate alerts to machine controllers if dimensions fall outside tolerance bounds, containing defect propagation.</p>
                </div>
              </div>
            </div>

            <div class="panel-section">
              <h4>Core Quality Modules</h4>
              <div class="sqm-features-list">
                <div class="sqm-item">
                  <h5 class="sqm-item__title">Inspection Standards</h5>
                  <p class="sqm-item__desc">Maps target dimension tolerances (LSL, USL) and test check lists per part number.</p>
                </div>
                <div class="sqm-item">
                  <h5 class="sqm-item__title">Real-Time Mobile QA</h5>
                  <p class="sqm-item__desc">Supports mobile-optimized entries for first-piece, runtime, and end-of-batch inspections.</p>
                </div>
                <div class="sqm-item">
                  <h5 class="sqm-item__title">Traceability Assurance</h5>
                  <p class="sqm-item__desc">Binds serial barcodes to inspect logs, enabling historical tracing on shipped items.</p>
                </div>
                <div class="sqm-item">
                  <h5 class="sqm-item__title">Analytics & SPC Charting</h5>
                  <p class="sqm-item__desc">Visualizes statistical process indicators and defect root-cause statistics.</p>
                </div>
              </div>
            </div>
          </div>

          <!-- 6. Web Custom Solution Content (Added Web Solution) -->
          <div class="services-panel" id="tab-web">
            <h3 class="panel-title">Custom Web Solutions</h3>
            <p class="panel-lead">Cross-platform accessibility and unified business data flows built on modern web standards.</p>

            <div class="panel-section">
              <h4>Web Solutions Overview</h4>
              <p>ISSOFT engineers robust, high-availability web systems allowing stakeholders to query business status and input records using any web browser. We guarantee full compatibility across varied devices (mobile, tablet, PC) and operating systems.</p>
            </div>

            <div class="panel-section grid grid--3">
              <div class="card">
                <div class="card__body">
                  <span class="badge">Web ERP & Portal</span>
                  <h5 class="card__title" style="margin-top: var(--space-md);">Integrated Portals</h5>
                  <p class="card__text" style="font-size: var(--font-size-sm);">Integrates sales, inventory, and production logs into a single web portal, providing live business KPI reporting to stakeholders.</p>
                </div>
              </div>
              <div class="card">
                <div class="card__body">
                  <span class="badge">Responsive WebApp</span>
                  <h5 class="card__title" style="margin-top: var(--space-md);">On-Floor Web Apps</h5>
                  <p class="card__text" style="font-size: var(--font-size-sm);">Equips storage yard and warehouse workers with responsive camera scanning web apps to record materials and shipments easily.</p>
                </div>
              </div>
              <div class="card">
                <div class="card__body">
                  <span class="badge">Live Monitoring</span>
                  <h5 class="card__title" style="margin-top: var(--space-md);">Remote Dashboards</h5>
                  <p class="card__text" style="font-size: var(--font-size-sm);">Allows off-site managers and logistics partners to track production rates and shipping schedules securely via web browsers.</p>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    // Highlight active nav item on scroll using IntersectionObserver
    const observerOptions = {
      root: null,
      rootMargin: '-150px 0px -60% 0px',
      threshold: 0
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          const navItems = document.querySelectorAll('.services-nav__item');
          navItems.forEach(item => {
            if (item.getAttribute('href') === `#${id}`) {
              item.classList.add('active');
            } else {
              item.classList.remove('active');
            }
          });
        }
      });
    }, observerOptions);

    document.querySelectorAll('.services-panel').forEach(panel => {
      observer.observe(panel);
    });
  </script>

  <Footer slot="footer" lang={lang} />
</BaseLayout>

<style>
  /* Stacked layout for services */
  .services-container {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  /* Nav Links Stylings - Fixed top sticky bar */
  .services-nav {
    display: flex;
    flex-direction: row;
    justify-content: center;
    gap: var(--space-xs);
    background: rgba(248, 250, 252, 0.85);
    padding: var(--space-xs);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border);
    position: sticky;
    top: 72px; /* sticky header height offset */
    z-index: 99;
    backdrop-filter: blur(10px);
    box-shadow: var(--shadow-sm);
  }

  .services-nav__item {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 10px var(--space-md);
    border-radius: var(--radius-md);
    text-decoration: none;
    font-weight: 600;
    color: var(--color-text-secondary);
    transition: all var(--transition-fast);
  }

  .services-nav__item:hover {
    background: rgba(242, 101, 34, 0.05);
    color: var(--color-brand-orange);
  }

  .services-nav__item.active {
    background: var(--brand-gradient);
    color: var(--color-white);
  }

  .services-nav__item.active .services-nav__icon {
    background-color: rgba(255, 255, 255, 0.2);
    color: var(--color-white);
    border-color: transparent;
  }

  .services-nav__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: var(--radius-sm);
    background-color: var(--color-white);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    transition: all var(--transition-fast);
    flex-shrink: 0;
  }

  .services-nav__icon svg {
    width: 12px;
    height: 12px;
    stroke-width: 2.5;
  }

  .services-nav__item:hover .services-nav__icon {
    color: var(--color-brand-orange);
    border-color: rgba(242, 101, 34, 0.2);
    background-color: var(--color-brand-orange-light);
  }

  .services-nav__text {
    font-size: var(--font-size-sm);
  }

  /* Classic MES/POP Diagram Styling strictly matching /images/0201.jpg with premium alignment */
  .mes-pop-classic-container {
    background-color: var(--color-bg-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-xl) var(--space-lg);
    margin-top: var(--space-md);
    text-align: center;
    user-select: none;
  }

  .mes-pop-classic {
    display: flex;
    align-items: center;
    justify-content: center;
    max-width: 540px;
    margin: 0 auto;
    gap: var(--space-sm);
  }

  .classic-node {
    font-size: 24px;
    font-weight: 700;
    color: var(--color-brand-orange); /* Changed blue to brand orange */
    font-family: var(--font-english);
    line-height: 1;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }

  .classic-line {
    display: flex;
    align-items: center;
    flex: 1;
    max-width: 120px;
    gap: 0;
  }

  .classic-connector {
    height: 1px;
    background-color: #cbd5e1;
    flex: 1;
  }

  .classic-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: 1px solid #cbd5e1;
    background-color: var(--color-white);
    flex-shrink: 0;
  }

  .classic-circle-outer {
    width: 104px;
    height: 104px;
    border-radius: 50%;
    background-color: var(--color-brand-orange-light); /* Changed light gray to light brand orange */
    border: 1px solid rgba(242, 101, 34, 0.15); /* Added soft brand border */
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .classic-circle-inner {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: var(--brand-gradient); /* Changed blue to brand gradient */
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .classic-circle-inner span {
    font-size: 11px;
    font-weight: 700;
    color: var(--color-white);
    line-height: 1.4;
    letter-spacing: -0.03em;
  }

  .classic-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .classic-dots span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--brand-gradient); /* Changed blue dots to brand gradient */
    display: inline-block;
  }

  .classic-desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    font-weight: 500;
  }

  @media (max-width: 767px) {
    .mes-pop-classic-container {
      padding: var(--space-lg) var(--space-md);
    }
    
    .mes-pop-classic {
      gap: var(--space-xs);
      max-width: 100%;
    }
    
    .classic-node {
      font-size: 20px;
    }
    
    .classic-line {
      max-width: 60px;
    }
    
    .classic-circle-outer {
      width: 90px;
      height: 90px;
    }
    
    .classic-circle-inner {
      width: 72px;
      height: 72px;
    }
    
    .classic-circle-inner span {
      font-size: 10px;
    }
    
    .classic-desc {
      font-size: 12px;
      line-height: 1.5;
    }
  }

  /* Content Panel Base Styling - Stacked Layout */
  .services-content {
    background: transparent;
    border: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3xl);
  }

  .services-panel {
    display: block;
    background: var(--color-white);
    border-radius: var(--radius-xl);
    padding: var(--space-2xl);
    border: 1px solid var(--color-border-light);
    box-shadow: var(--shadow-sm);
    scroll-margin-top: 140px; /* Offset for header and sticky nav */
    animation: fadeIn var(--transition-base) forwards;
  }

  .panel-title {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-xs);
    color: var(--color-text-primary);
  }

  .panel-lead {
    font-size: var(--font-size-md);
    color: var(--color-brand-orange);
    font-weight: 600;
    margin-bottom: var(--space-2xl);
  }

  .panel-section {
    margin-bottom: var(--space-2xl);
  }

  .panel-section:last-child {
    margin-bottom: 0;
  }

  .panel-section h4 {
    font-size: var(--font-size-lg);
    margin-bottom: var(--space-md);
    position: relative;
    padding-left: var(--space-sm);
  }

  .panel-section h4::before {
    content: '';
    position: absolute;
    left: 0;
    top: 6px;
    bottom: 6px;
    width: 3px;
    background: var(--brand-gradient);
    border-radius: var(--radius-full);
  }

  .panel-section p {
    font-size: var(--font-size-base);
    line-height: 1.8;
  }

