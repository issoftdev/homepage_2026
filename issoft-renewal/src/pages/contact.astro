---
// 문의하기 Page — (주)이즈소프트
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const lang = 'ko';
const currentPath = '/contact/';
---

<BaseLayout
  title="문의하기 | (주)이즈소프트"
  description="이즈소프트 본사 위치와 연락처 정보입니다. 대구 동구 공항로 이즈빌딩 5층에 위치해 있으며, 전화 또는 이메일로 상담이 가능합니다."
  lang={lang}
  currentPath={currentPath}
>
  <Header slot="header" lang={lang} currentPath={currentPath} />

  <!-- Page Hero -->
  <section class="page-hero" aria-label="페이지 헤더">
    <div class="container">
      <div class="page-hero__breadcrumb">
        <a href="/">홈</a>
        <span>&gt;</span>
        <span>문의하기</span>
      </div>
      <h1 class="page-hero__title">Contact Us</h1>
      <p class="page-hero__desc">언제든 이즈소프트에 연락 주시면 성심껏 상담해 드리겠습니다.</p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="section" aria-labelledby="contact-main-title">
    <div class="container">
      <h2 class="sr-only" id="contact-main-title">연락처 및 위치 정보</h2>

      <!-- Top Column Grid: Info Cards -->
      <div class="contact-cards-grid fade-in">
        <!-- Card 1: Address -->
        <div class="contact-info-card">
          <div class="contact-info-card__icon-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div class="contact-info-card__body">
            <h4>주소</h4>
            <p>(41051) 대구광역시 동구 공항로56길 5, 이즈빌딩 5층 (주)이즈소프트</p>
          </div>
        </div>
        
        <!-- Card 2: Phone -->
        <div class="contact-info-card">
          <div class="contact-info-card__icon-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <div class="contact-info-card__body">
            <h4>대표 전화</h4>
            <p><a href="tel:053-743-8235" class="contact-link">053-743-8235</a></p>
          </div>
        </div>

        <!-- Card 3: Email -->
        <div class="contact-info-card">
          <div class="contact-info-card__icon-box">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div class="contact-info-card__body">
            <h4>이메일 문의</h4>
            <p><a href="mailto:ckkang@issoftware.co.kr" class="contact-link">ckkang@issoftware.co.kr</a></p>
          </div>
        </div>
      </div>

      <!-- Bottom Split Layout -->
      <div class="contact-main-layout fade-in">
        <!-- Left Column: Inquiry Form -->
        <div class="contact-form-container">
          <h3 class="contact-form__title">온라인 도입 문의</h3>
          <p class="contact-form__subtitle">이즈소프트의 솔루션에 대한 제안 요청 및 상담 신청서를 남겨주세요.</p>
          
          <form id="inquiryForm" class="contact-form">
            <!-- Web3Forms Config -->
            <input type="hidden" name="access_key" value="e76173f8-6668-4b7e-b384-388e6ca3c0d8" />
            <input type="hidden" name="subject" value="[이즈소프트 홈페이지] 새로운 온라인 도입 문의 접수" />
            <input type="hidden" name="from_name" value="이즈소프트 웹사이트" />

            <div class="form-row">
              <div class="form-group">
                <label for="input-name">회사명 / 담당자명 <span class="required">*</span></label>
                <input type="text" id="input-name" name="name" required placeholder="예: (주)이즈소프트 / 홍길동" />
              </div>
              <div class="form-group">
                <label for="input-contact">연락처 <span class="required">*</span></label>
                <input type="tel" id="input-contact" name="contact" required placeholder="예: 010-0000-0000" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-group">
                <label for="input-email">이메일 주소 <span class="required">*</span></label>
                <input type="email" id="input-email" name="email" required placeholder="example@email.com" />
              </div>
              <div class="form-group">
                <label for="input-category">문의 부문 <span class="required">*</span></label>
                <select id="input-category" name="category" required>
                  <option value="">선택해 주세요</option>
                  <option value="스마트공장 (POP/MES)">스마트공장 (POP / MES)</option>
                  <option value="지능형 설비제어 (MICS)">지능형 설비제어 (MICS)</option>
                  <option value="L-CRIS 개발프레임워크">L-CRIS 개발프레임워크</option>
                  <option value="웹기반 맞춤 솔루션">웹기반 맞춤 솔루션</option>
                  <option value="기타 비즈니스 문의">기타 비즈니스 문의</option>
                </select>
              </div>
            </div>

            <div class="form-group">
              <label for="input-message">상세 문의내용 <span class="required">*</span></label>
              <textarea id="input-message" name="message" rows="5" required placeholder="구축하고자 하는 프로젝트의 배경, 요구 사항, 예상 일정 등을 자유롭게 기술해 주시면 전문가가 신속하게 진단해 드립니다."></textarea>
            </div>

            <button type="submit" class="btn submit-btn">
              <span>문의 신청하기</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
              </svg>
            </button>
          </form>

          <!-- Success Alert Overlay -->
          <div id="formSuccess" class="form-success-overlay" style="display: none;">
            <div class="form-success-content">
              <div class="form-success-icon">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"/>
                </svg>
              </div>
              <h4>성공적으로 접수되었습니다!</h4>
              <p>기입해 주신 내용을 바탕으로 면밀히 검토한 후, 남겨주신 이메일 또는 연락처를 통해 담당 전문가가 신속하게 응대해 드리겠습니다. 감사합니다.</p>
              <button type="button" class="btn btn--outline btn--sm" style="margin-top: var(--space-sm);" onclick="document.getElementById('formSuccess').style.display='none';">확인</button>
            </div>
          </div>
        </div>

        <!-- Right Column: Kakao Map Container -->
        <div class="contact-map-container">
          <h3 class="contact-map__title">오시는 길</h3>
          <div class="contact-map">
            <h3 class="sr-only">카카오맵 지도</h3>
            <!-- Kakao Map Node -->
            <div id="daumRoughmapContainer1587969578649" class="root_daum_roughmap root_daum_roughmap_landing"></div>
            
            <!-- Kakao Map Link -->
            <div class="map-actions">
              <a
                href="https://map.kakao.com/?q=%EB%8C%80%EA%B5%AC%20%EB%8F%99%EA%B5%AC%20%EA%B3%B5%ED%95%AD%EB%A1%9C56%EA%B8%B8%205"
                target="_blank"
                rel="noopener noreferrer"
                class="map-link-btn"
              >
                <span>카카오맵에서 크게보기</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" lang={lang} />

  <!-- Kakao Map Loader scripts (using is:inline to execute strictly in client) -->
  <script is:inline charset="UTF-8" src="https://ssl.daumcdn.net/dmaps/map_js_init/roughmapLoader.js"></script>
  <script is:inline>
    // Initialize Kakao roughmap
    new daum.roughmap.Lander({
      "timestamp" : "1587969578649",
      "key" : "y5mk",
      "mapWidth" : "100%",
      "mapHeight" : "420"
    }).render();

    // Handle form submit via AJAX
    const form = document.getElementById('inquiryForm');
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        const submitBtn = form.querySelector('.submit-btn');
        const submitBtnText = submitBtn.querySelector('span');
        const originalText = submitBtnText.textContent;
        
        submitBtnText.textContent = '전송 중...';
        submitBtn.disabled = true;

        const formData = new FormData(form);
        const object = Object.fromEntries(formData);
        const json = JSON.stringify(object);

        fetch('https://api.web3forms.com/submit', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: json
        })
        .then(async (response) => {
          let jsonRes = await response.json();
          if (response.status == 200) {
            document.getElementById('formSuccess').style.display = 'flex';
            form.reset();
          } else {
            alert('오류가 발생했습니다: ' + jsonRes.message);
          }
        })
        .catch(error => {
          alert('전송 중 네트워크 오류가 발생했습니다. 잠시 후 다시 시도해 주세요.');
        })
        .then(() => {
          submitBtnText.textContent = originalText;
          submitBtn.disabled = false;
        });
      });
    }
  </script>
</BaseLayout>

<style>
  /* 3-Column Info Cards Grid */
  .contact-cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
    margin-bottom: var(--space-2xl);
  }

  .contact-info-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: var(--space-xl);
    display: flex;
    align-items: flex-start;
    gap: var(--space-lg);
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-normal);
  }

  .contact-info-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-brand-orange-light);
  }

  .contact-info-card__icon-box {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-brand-orange-light);
    color: var(--color-brand-orange);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    box-shadow: 0 4px 10px rgba(242, 101, 34, 0.1);
  }

  .contact-info-card__body h4 {
    font-size: var(--font-size-base);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--space-xs);
  }

  .contact-info-card__body p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    word-break: keep-all;
  }

  .contact-link {
    color: var(--color-text-primary);
    text-decoration: none;
    font-weight: 600;
    transition: color 0.2s ease;
  }

  .contact-link:hover {
    color: var(--color-brand-orange);
  }

  /* Bottom Split Layout */
  .contact-main-layout {
    display: grid;
    grid-template-columns: 1.25fr 0.75fr;
    gap: var(--space-2xl);
    align-items: stretch;
  }

  /* Form Styling */
  .contact-form-container {
    background: var(--color-white);
    border: 1px solid var(--color-border-light);
    border-radius: var(--radius-2xl);
    padding: var(--space-2xl);
    box-shadow: var(--shadow-sm);
    position: relative;
    overflow: hidden;
  }

  .contact-form__title {
    font-size: var(--font-size-xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 2px;
  }

  .contact-form__subtitle {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xl);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xs);
  }

  .form-group label {
    font-size: var(--font-size-xs);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: -0.01em;
  }

  .form-group label .required {
    color: #ef4444;
    margin-left: 2px;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    font-family: inherit;
    font-size: var(--font-size-sm);
    padding: 12px var(--space-md);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: var(--color-bg-alt);
    color: var(--color-text-primary);
    transition: all var(--transition-fast);
    outline: none;
    width: 100%;
    box-sizing: border-box;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    border-color: var(--color-brand-orange);
    background-color: var(--color-white);
    box-shadow: 0 0 0 3px rgba(242, 101, 34, 0.15);
  }

  .form-group textarea {
    resize: vertical;
  }

  .submit-btn {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    padding: 14px var(--space-xl);
    background: var(--brand-gradient);
    color: var(--color-white);
    border: none;
    border-radius: var(--radius-md);
    font-weight: 700;
    cursor: pointer;
    transition: all var(--transition-normal);
    box-shadow: 0 4px 14px rgba(242, 101, 34, 0.3);
  }

  .submit-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(242, 101, 34, 0.4);
  }

  .submit-btn svg {
    transition: transform 0.2s ease;
  }

  .submit-btn:hover svg {
    transform: translateX(4px);
  }

  /* Form Success Overlay */
  .form-success-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(255, 255, 255, 0.98);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2xl);
    z-index: 10;
    backdrop-filter: blur(8px);
    animation: fadeIn 0.3s ease-out;
  }

  .form-success-content {
    text-align: center;
    max-width: 440px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .form-success-icon {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background-color: #10b981;
    color: var(--color-white);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(16, 185, 129, 0.3);
  }

  .form-success-content h4 {
    font-size: var(--font-size-xl);
    font-weight: 800;
    color: var(--color-text-primary);
  }

  .form-success-content p {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin: 0;
    word-break: keep-all;
  }

  /* Map Styling */
  .contact-map-container {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .contact-map__title {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .contact-map {
    background: var(--color-white);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-sm);
    border: 1px solid var(--color-border-light);
    overflow: hidden;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  :global(.root_daum_roughmap) {
    border: none !important;
    font-family: var(--font-primary) !important;
    width: 100% !important;
    box-sizing: border-box;
    flex-grow: 1;
  }

  :global(.root_daum_roughmap .wrap_map) {
    width: 100% !important;
    height: 100% !important;
    min-height: 380px;
  }

  :global(.root_daum_roughmap .map) {
    width: 100% !important;
    height: 100% !important;
  }

  .map-actions {
    padding: var(--space-md);
    background: var(--color-bg-alt);
    display: flex;
    justify-content: center;
    border-top: 1px solid var(--color-border);
  }

  .map-link-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--color-text-secondary);
    font-weight: 600;
    font-size: var(--font-size-sm);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .map-link-btn:hover {
    color: var(--color-brand-orange);
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 1023px) {
    .contact-cards-grid {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .contact-main-layout {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    :global(.root_daum_roughmap .wrap_map) {
      min-height: 320px;
      height: 320px !important;
    }
  }

  @media (max-width: 767px) {
    .contact-form-container {
      padding: var(--space-lg);
    }

    .form-row {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .submit-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
